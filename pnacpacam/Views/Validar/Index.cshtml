@{
    ViewBag.Title = "Validador de Documento";

}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title</title>
    @Styles.Render("~/plugins-css")
    @Styles.Render("~/core-css")
</head>
<body>
    <header>
        <div class="navbar navbar-default navbar-fixed-top">
            <div class="container-fluid">
                <div class="navbar-header">
                    <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
                        <span class="icon-bar"></span>
                        <span class="icon-bar"></span>
                        <span class="icon-bar"></span>
                    </button>
                </div>

            </div>
        </div>
    </header>
    <main>
        <div class="container-fluid margin-top">
            <div class="col-md-12">
                <div class="row">
                    <div class="container">
                        <center><h1>@ViewBag.Title</h1></center><hr>

                        <div class="col-md-4 col-md-offset-4">
                            
                             using (Html.BeginForm("Verificar", "Validar", FormMethod.Post))
                             {
                                @Html.AntiForgeryToken()
                                <h3><center>Bienvenido</center></h3>
                                <p><center>Ingrese los siguientes datos:</center></p>
                                <div class="form-group">
                                    <label>ID del Documento</label>
                                    <input value="@ViewBag.IdDocumento" type="text" class="form-control required" id="IdDocumento" name="IdDocumento" placeholder="ID Documento" aria-required="true">
                                </div>
                                <div class="form-group">
                                    <label>Codigo de Verificacion</label>
                                    <input value="@ViewBag.CodigoVerificacion" type="text" class="form-control required" id="CodigoVerificacion" name="CodigoVerificacion" placeholder="Codigo Verificacion" aria-required="true">
                                </div>
                                <input type="submit" class="btn btn-primary btn-block" value="Continuar"/>
                                <div id="message">@ViewBag.Documento</div>
                               
                             }
                        </div>
                    </div>
                </div>

                @Scripts.Render("~/core-js")
            </div>
            <!--fin side bar-->
        </div>
    </main>
    @Html.Partial("_Footer")
</body>
</html>
