    <div class="labelFiltro"> DOCUMENTOS ADJUNTOS </div>
    <table id="tablaDocumentosAdjuntos-1" class="tabla-documentos">
        <thead>
            <tr>
                <th>#</th>
                <th>Nombre del archivo</th>
            </tr>
        </thead>
        <tbody>
            <!-- Aquí se llenan las filas desde el AJAX -->
        </tbody>
    </table>
</div>


<div class="panel panel-primary" style="background-color: aliceblue;">
    <div class="labelFiltro"> FACTURA COMISION </div>
    <div class="labelFiltro" id="upload_facturaComision"> </div>
</div>