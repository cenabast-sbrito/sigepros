@model pnacpacam.Models.VariablesEntorno

@{
    Layout = null;
}
@Html.AntiForgeryToken()




<div class="panel panel-primary">

    <div class="row">

        <div class="titulo-principal" style="display:flex; align-items:center;">
            <h2>Gestión de los Expedientes de Proveedores</h2>

            <p class="panel-body" style="font-size: 1.2rem; margin-left: auto; text-align: right;">
                <input type="checkbox" id="incluirDatosAdicionales" name="SS" />
                <label for="incluirDatosAdicionales">
                    Excluir Datos acerca del Servicio de Salud, Rut del Establecimiento y Destinatario en Datos de Guías
                    <small>(excluir esta información, disminuye el tiempo de espera al consultar las Guías)</small>
                </label>
            </p>
        </div>


    </div>

    <form role="form" id="form-upload" method="POST" enctype="multipart/form-data" asp-action="UploadFile">

        <div class="panel-heading">

            <div class="" style="width: 100%;">

                <div class="">

                    <!-- PANEL FILTROS -->
                    @Html.Partial("Shared/_Filtro", new pnacpacam.Models.Seleccion { item = "filtroFacturas" })

                </div>

            </div>

        </div>


    </form>

</div>


<style>

    /* Contenedor principal de la fila */
    .modal-body .row.flex-layout {
        display: flex;
        height: calc(100vh - 140px); /* ocupa todo el alto útil del modal */
    }

    /* Panel izquierdo (tablas) */
    .modal-body .panel-izquierdo {
        width: 62%;
        overflow: auto;
        padding-right: 10px;
    }

    /* Panel derecho (documentos + iframe) */
    .modal-body .panel-derecho {
        width: 38%;
        display: flex;
        flex-direction: column;
    }

    /* Tabla documentos */
    .panel-derecho .tabla-documentos-container {
        max-height: 38%;
        overflow: auto;
    }

    /* Iframe visor PDF */
    #iframeGuiaWrapper {
        flex: 1; /* ocupa TODO el espacio restante */
        margin-top: 10px;
    }

    #_guiaPreview {
        width: 100%;
        height: 100%;
        border: 2px solid #4e46e5;
    }

    .row {
        width: 100%;
        margin: 0 auto;
    }

    /* estilo ícono observacion */

    .icon-observacion {
        color: #b35400; /* naranja oscuro */
        font-size: 20px;
        margin-left: 6px;
        cursor: pointer;
        transition: transform .15s ease, opacity .15s ease;
    }

        .icon-observacion:hover {
            transform: scale(1.15);
            opacity: 0.85;
        }

    /* estilo del modal */

    .modal-content {
        height: 100%;
    }

    .modal-body {
        height: calc(100% - 110px); /* header + footer */
        overflow: hidden; /* el scroll lo manejarán los paneles */
    }
</style>

<!-- PANEL FACTURAS -->


@Html.Partial("Tablas/_Tablas", new pnacpacam.Models.Seleccion { item = "Facturas" })

@*</div>*@
<!-- FIN PANEL FACTURAS -->
<!-- MODAL GUIAS -->
<div class="modal top fade" id="_Factura_Guias" role="dialog" tabindex="-1" aria-labelledby="" data-backdrop="static" style="overflow:auto">
    <div class="modal-dialog" role="document" style="width: 98vw; max-width: none; height: 98vh; margin: 0;">
        <div class="modal-content">
            <div class="modal-header bg-primary">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close" onclick="resetFormExpedienteVer();">
                    <span aria-hidden="true">&times;</span>
                </button>
                <h4 class="modal-title" id="">Guías</h4>
            </div>
            <form id="formVerGuias">

                @Html.AntiForgeryToken()

                <div class="modal-body">

                    <div class="row flex-layout">

                        <!-- IZQUIERDA -->
                        <div class="panel-izquierdo">
                            <div class="tablas">
                                @Html.Partial("Tablas/_Tablas", new pnacpacam.Models.Seleccion { item = "Guias" })
                            </div>
                        </div>

                        <!-- DERECHA -->
                        <div class="panel-derecho">

                            <h3>Documentos del proveedor</h3>

                            <div class="tabla-documentos-container">

                                <div id="spinnerDocumentos" class="text-center table-overlay" style="display:none; padding:20px">
                                    <i class="fas fa-spinner fa-spin fa-3x"></i>
                                    <div>Buscando documentos...</div>
                                </div>

                                <table id="tablaDocumentos" class="tabla-documentos">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>Nombre del archivo</th>
                                            <th>Ver</th>
                                        </tr>
                                    </thead>
                                    <tbody></tbody>
                                </table>
                            </div>

                            <!-- VISOR PDF -->
                            <div id="iframeGuiaWrapper">
                                <iframe id="_guiaPreview" name="_guiaPreview"></iframe>
                            </div>

                        </div>

                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" data-dismiss="modal" onclick="resetFormExpedienteVer();">Salir</button>
                </div>

            </form>
        </div>
    </div>
</div>
<!-- FIN MODAL GUIAS -->
<!-- MODAL DOCUMENTOS ADJUNTOS -->
<div class="modal top fade" id="modal_Documentos_Adjuntos" role="dialog" tabindex="-1" aria-labelledby="" data-backdrop="static" style="overflow:auto">
    <div class="modal-dialog" role="document" style="width: 98vw; max-width: none; height: 98%; margin: 0;">
        <div class="modal-content">
            <div class="modal-header bg-primary">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close" onclick="resetFormDocumentosAdjuntosVer();">
                    <span aria-hidden="true">&times;</span>
                </button>
                <h4 class="modal-title" id="">Documentos Adjuntos</h4>
            </div>
            <form id="formVerDocumentosAdjuntos">

                @Html.AntiForgeryToken()

                <div class="modal-body">

                    <div class="form-group">
                        <div class="row">
                            <div class="block1">
                                <div class="tablas">

                                    @Html.Partial("Tablas/_Tablas", new pnacpacam.Models.Seleccion { item = "DocumentosAdjuntos" })

                                </div>
                            </div>
                            <div class="block2">


                                <style>
                                    /* Estilos generales de la tabla */
                                    .tabla-documentos {
                                        width: 100%;
                                        border-collapse: collapse;
                                        margin: 20px 0;
                                        font-family: "Segoe UI", Arial, sans-serif;
                                        font-size: 14px;
                                        color: #333;
                                    }

                                        /* Encabezados */
                                        .tabla-documentos thead th {
                                            background-color: #f5f5f5;
                                            color: #444;
                                            text-align: left;
                                            padding: 10px 15px;
                                            border-bottom: 2px solid #ddd;
                                        }

                                        /* Celdas */
                                        .tabla-documentos td {
                                            padding: 10px 15px;
                                            border-bottom: 1px solid #eee;
                                            vertical-align: middle;
                                        }

                                        /* Hover para filas */
                                        .tabla-documentos tbody tr:hover {
                                            background-color: #fafafa;
                                        }

                                        /* Columna índice */
                                        .tabla-documentos td:first-child {
                                            width: 40px;
                                            text-align: center;
                                            color: #666;
                                        }

                                        /* Ícono de ver */
                                        .tabla-documentos a i {
                                            color: #007bff;
                                            transition: color 0.2s, transform 0.2s;
                                        }

                                            .tabla-documentos a i:hover {
                                                color: #0056b3;
                                                transform: scale(1.1);
                                            }
                                </style>


                                <!-- style del Spinner -->
                                <style>
                                    .box-loading {
                                        min-height: 120px;
                                    }

                                    .loading-overlay {
                                        position: absolute;
                                        inset: 0;
                                        background: rgba(255, 255, 255, 0.75);
                                        display: flex;
                                        flex-direction: column;
                                        align-items: center;
                                        justify-content: center;
                                        z-index: 10;
                                        border-radius: 6px;
                                    }

                                        .loading-overlay i {
                                            font-size: 2rem;
                                            color: #0061aa;
                                            margin-bottom: 6px;
                                        }

                                        .loading-overlay span {
                                            font-size: 0.9rem;
                                            color: #0061aa;
                                            font-weight: 600;
                                        }
                                </style>

                                <div class="box-loading position-relative">

                                    <!-- Spinner -->
                                    <div class="loading-overlay d-none">
                                        <i class="fas fa-spinner fa-spin"></i>
                                        <span>Cargando...</span>
                                    </div>

                                    <!-- Contenido real -->
                                    <div class="box-content">
                                        <!-- aquí va tu tabla, formulario, panel, etc -->
                                        Contenido del cuadro
                                    </div>

                                </div>

                                <h3>Documentos del proveedor</h3>
                                <table id="tablaDocumentosAdjuntos" class="tabla-documentos">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>Nombre del archivo #2</th>
                                            <th>Ver</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <!-- Aquí se llenan las filas desde el AJAX -->
                                    </tbody>
                                </table>

                                <iframe id="_guiaPreviewDocumentoAdjunto" name="_guiaPreviewDocumentoAdjunto" style="border:2px solid #4e46e5;"></iframe>


                                @*<div class="row"><div id="_guiaPedidoCompra"></div><div id="_guiaMaterial"></div></div>
                                    <div class="row"><iframe id="_guiaPreview" name="_guiaPreview" style="border:2px solid #4e46e5;"></iframe></div>*@
                            </div>
                        </div>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" data-dismiss="modal" onclick="resetFormDocumentoAdjuntoVer();">Salir</button>
                </div>

            </form>
        </div>
    </div>
</div>
<!-- FIN MODAL DOCUMENTOS ADJUNTOS -->
