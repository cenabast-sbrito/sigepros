<!-- MODAL ACEPTADO CON OBSERVACION -->
<div class="modal fade modal-institucional" id="_Acepta_Observacion"
     tabindex="-1" data-backdrop="static" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">

            <div class="modal-header">
                <h4 class="modal-title">
                    Confirmar aceptación
                </h4>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <!-- Estado OK -->
                <div class="estado estado-ok" >
                    <input type="text" id="modal_TEstadoOK" readonly  style="font-size:1.8rem;"/>
                </div>

                <!-- Estado NO OK -->
                <div class="estado estado-nook">
                    <input type="text" id="modal_TEstadoNOOK" readonly style="font-size:1.8rem;" />
                </div>

                <p class="texto-explicativo">
                    Usted está a punto de actualizar el estado del expediente
                    para que pueda ser visado por otras personas.
                </p>

                <div class="form-group">

                    <input type="text"
                           id="_CampoObservacion"
                           class="form-control"
                           placeholder="Ingrese una observación clara y breve" />
                </div>

                <!-- Campos ocultos -->
                <input type="hidden" id="modal_rut" />
                <input type="hidden" id="modal_factura" />
                <input type="hidden" id="modal_estadoActual" />
                <input type="hidden" id="modal_estadoNuevo" />
                <input type="hidden" id="modal_fila" />
                <input type="hidden" id="modal_obj" />

                <div id="_mensaje_Observaciones" class="mensaje-observacion"></div>

            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-primary"
                        id="_acepta-cambio-estado">
                    Aceptar
                </button>
                <button type="button"
                        class="btn btn-secondary"
                        data-dismiss="modal">
                    Cancelar
                </button>
            </div>

        </div>
    </div>
</div>
<!-- FIN MODAL -->
