                    </div>

                    <div class="row form-group" style="margin-top: 25px;">

                        <!-- asignar roles -->
                        <div class="container-datatable">
                            <div class="row">
                                <table class="table table-hover table-bordered table-striped table-border-blue" id="tableroRolesDelUsuario" style="width:100%">
                                    <thead class="thead-bgcolor">
                                        <tr>
                                            <th>Rol</th>
                                            <th>Descripción</th>
                                        </tr>
                                    </thead>
                                </table>
                            </div>
                        </div>
                    </div>

                </div>

                    <!-- Pie del Modal -->
                    <div class="modal-footer">
                        @*<button id="guardarRolUsuario" type="button" class="btn btn-primary">Guardar  </button>
                        <button id="modificarRolUsuario" type="button" class="btn btn-primary">Modificar</button>*@
                        <button type="button" class="btn btn-primary" data-dismiss="modal">Cerrar</button>
                    </div>

            </form>

        </div>
    </div>
</div>

