                <span id="msjeAlertaRep"></span>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-sm-2 col-xs-12">
            <input type='month' name='periodoCierreB' id='periodoCierreB' class='form-control input-sm' value='2022-01'>
