
@Html.Partial("_Header")
@RenderBody()
<header>
    <div class="navbar navbar-default navbar-fixed-top">
        <div class="container-fluid">
            <div class="navbar-header">
                <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                </button>
                <a class="navbar-brand" href="#">Inventario</a>
            </div>

            <!--MENU-->
            <div class="navbar-collapse collapse">
                <ul class="nav navbar-nav menu-principal">
                    <li>
                        <a href="#lista-inventarios" aria-controls="crear-cdc" role="tab" data-toggle="tab">Inventarios</a>
                    </li>
                    <!-- AQUI ES DONDE SE ASIGNA LA PESTAÑA PARA EL PERFIL EN _ADMINLAYOUT NO se controla totalmente
    <li>
        <a href="#crear-indicador-complementario" aria-controls="crear-indicador-complementario" role="tab" data-toggle="tab">Indicador Complementario</a>
    </li>
    -->
                    <li>
                        <a href="#admin-lista-inventarios" aria-controls="admin-lista-inventarios" role="tab" data-toggle="tab">Detalle Inventarios</a>
                    </li>
                    <li>
                        <a href="#reportes" aria-controls="reportes" role="tab" data-toggle="tab">Reportabilidad</a>
                    </li>
                    <li>
                        <a href="#carga-Inventario" aria-controls="Subida de Inventarios" role="tab" data-toggle="tab">Carga</a>
                    </li>
                    <li>
                        <a href="#cierre-Inventario" aria-controls="Cierre de Mes" role="tab" data-toggle="tab">Cierre Mensual</a>
                    </li>
                    <li>
                        <a href="#cierre" aria-controls="Cierre" role="tab" data-toggle="tab">Cierre</a>
                    </li>
                    <li>
                        <a href="#compra" aria-controls="Compras" role="tab" data-toggle="tab">Compras</a>
                    </li>
                    <li>
                        <a href="#producto" aria-controls="Productos" role="tab" data-toggle="tab">Productos</a>
                    </li>
                </ul>
                <ul class="nav navbar-nav navbar-right">
                    <li class="dropdown">
                        <a href="#" class="dropdown-toggle" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="false">(_controlgestionLayout) Bienvenido: <strong id="Username" style="margin:3px">@Session["Nombre"]</strong> <span class="fas fa-user" aria-hidden="true" style="margin:2px"></span> <span class="caret"></span></a>
                        <ul class="dropdown-menu">
                            <!--<li><a id="PerfilUser" href="#">Something else here</a></li>
                            <li role="separator" class="divider"></li>-->
                            <li><a id="logout" href="#">Cerrar Sesión <span class="fas fa-power-off" aria-hidden="true"></span></a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</header>

<main>

    <!--CONTENIDO-->
    <div class="container-fluid margin-top">
        <div class="col-md-12">
            <!-- Tab panes -->
            <div class="tab-content">
                <div role="tabpanel" class="tab-pane fade" id="administrador-lista-inventarios">
                    @Html.Partial("Admin/_Inventario")
                </div>
                <div role="tabpanel" class="tab-pane fade" id="admin-lista-inventarios">
                    @Html.Partial("Admin/_ListaInventarios")
                </div>
                <div role="tabpanel" class="tab-pane fade" id="reportes">
                    @Html.Partial("Admin/_Reportes")
                </div>
                <div role="tabpanel" class="tab-pane fade" id="carga-Inventario">
                    @Html.Partial("Admin/_CargaInventario")
                </div>
                <div role="tabpanel" class="tab-pane fade" id="cierre-Inventario">
                    @Html.Partial("Admin/_CierreInventario")
                </div>
                <div role="tabpanel" class="tab-pane fade" id="cierre">
                    @Html.Partial("Admin/_Cierre")
                </div>
                <div role="tabpanel" class="tab-pane fade" id="compra">
                    @Html.Partial("Admin/_Compra")
                </div>
                <div role="tabpanel" class="tab-pane fade" id="producto">
                    @Html.Partial("Admin/_Producto")
                </div>
            </div>
            <!--FIN CONTENIDO-->
            <!-- Modal Mensaje -->
            <div id="modalMensajeSistema" class="modal fade" tabindex="-1" role="dialog">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-content">
                            <div class="modal-header">
                                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                                <h4 class="modal-title text-center">Atención: </h4>
                            </div>
                            <div class="modal-body">
                                <div class="alert alert-warning" role="alert">
                                    <strong>Atención!</strong><p id="mensajeSistema"></p>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-default" data-dismiss="modal">Aceptar</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!--fin side bar-->
    </div>

    <!-- Modal Sesión Expiró -->
    <div class="modal fade" id="SesionExpiroNotif" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><b>Control de Sesión</b></h5>
                </div>
                <div class="modal-body text-center">
                    <div class="row col-md-12" style="font-size:1.2em;">
                        <span>Su sesión está por expirar. Haga clic en el botón si desea mantener activa la sesión actual.</span>
                    </div>

                    <div class="row col-md-12" style="padding:15px 0">
                        <b><span id="tiemporestante" class="label label-warning" style="font-size:1.8em;"></span></b>
                    </div>
                </div>
                <div class="clearfix"></div>
                <div class="modal-footer text-center">
                    <button id="btnMantenerSesion" type="button" class="btn btn-principal" data-dismiss="modal">Mantener sesión activa</button>
                </div>
            </div>
        </div>
    </div>
    <!-- Fin Modal Sesión Expiró -->

</main>

@Scripts.Render("~/core-js")
@Scripts.Render("~/plugins-js")


<script type="text/javascript" src="@Url.Content("~/app" + "?v=" + File.GetLastWriteTime(HttpContext.Current.Request.MapPath("~/Scripts/js/app/app.js")).ToString("yyyyMMddHHHmm"))"></script>
<script type="text/javascript" src="@Url.Content("~/inventario" + "?v=" + File.GetLastWriteTime(HttpContext.Current.Request.MapPath("~/Scripts/js/app/inventario.js")).ToString("yyyyMMddHHHmm"))"></script>
<script type="text/javascript" src="@Url.Content("~/carga" + "?v=" + File.GetLastWriteTime(HttpContext.Current.Request.MapPath("~/Scripts/js/app/cargaInventario.js")).ToString("yyyyMMddHHHmm"))"></script>

<script type="text/javascript" src="@Url.Content("~/cierre" + "?v=" + File.GetLastWriteTime(HttpContext.Current.Request.MapPath("~/Scripts/js/app/cierreInventario.js")).ToString("yyyyMMddHHHmm"))"></script>
<script type="text/javascript" src="@Url.Content("~/producto" + "?v=" + File.GetLastWriteTime(HttpContext.Current.Request.MapPath("~/Scripts/js/app/producto.js")).ToString("yyyyMMddHHHmm"))"></script>

<script type="text/javascript" src="@Url.Content("~/revision-mv" + "?v=" + File.GetLastWriteTime(HttpContext.Current.Request.MapPath("~/Scripts/js/app/revision-mv.js")).ToString("yyyyMMddHHHmm"))"></script>
<script type="text/javascript" src="@Url.Content("~/reporte" + "?v=" + File.GetLastWriteTime(HttpContext.Current.Request.MapPath("~/Scripts/js/app/reporte.js")).ToString("yyyyMMddHHHmm"))"></script>





@Html.Partial("_Footer")



