<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Expires" content="0">
    <meta http-equiv="Last-Modified" content="0">
    <meta http-equiv="Cache-Control" content="no-cache, mustrevalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <title>@ViewBag.Title</title>

    @Styles.Render("~/css")
    @Styles.Render("~/plugins-css")
</head>
<body>
    <header>
        <div class="navbar navbar-default navbar-fixed-top">
            <div class="container-fluid">
                <div class="navbar-header">
                    <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
                        <span class="icon-bar"></span>
                        <span class="icon-bar"></span>
                        <span class="icon-bar"></span>
                    </button>
                    <a href="#"><img alt="Brand" src="https://aplicacionesweb.cenabast.cl/icp/bootstrap/img/logotipo3.png"></a>
                </div>
            </div>
        </div>
    </header>
    <main>
        <div class="container-fluid margin-top">
                <div class="row col-md-12" style="margin:25px auto;">
                    <div class="col-md-3"></div>
                    <div class="container col-md-6" style="background-color: white; padding:40px 20px 80px 20px;">
                        <center><h2>CONTROL Y SEGUIMIENTO DEL INVENTARIO BIENESTAR</h2></center><hr>
                        <center>
                            <h3>
                                <small>Esta plataforma permite el control y seguimiento del inventario, consultar y emitir reportes </small>
                            </h3>
                        </center>
                        <div class="row">
                            <div class="col-md-3"></div>
                            <form class="form-horizontal col-md-6" id="formLogin" method="post">
                                @Html.AntiForgeryToken()
                                <center><h3>Ingreso</h3></center>
                                <div class="form-group">
                                    <label>Usuario</label>
                                    <input type="text" class="form-control required rut" id="username" name="username" placeholder="Rut" aria-required="true">
                                </div>
                                <div class="form-group">
                                    <label>Password</label>
                                    <input type="password" class="form-control required" id="password" name="password" placeholder="Password" aria-required="true">
                                </div>
                                <div class="form-group">
                                    <button type="submit" class="btn btn-block btn-principal">Ingresar</button>
                                    <div id="message"></div>
                                </div>
                            </form>
                            <div class="col-md-3"></div>
                        </div>
                    </div>
                    <div class="col-md-3"></div>
                </div>

                @Scripts.Render("~/core-js")
                @Scripts.Render("~/plugins-js")
                
                <script type="text/javascript" src="@Url.Content("~/login" + "?v=" + File.GetLastWriteTime(HttpContext.Current.Request.PhysicalApplicationPath).ToString("yyyyMMddHHHmm"))"></script>

            </div>
            <!--fin side bar-->
    </main>
    @Html.Partial("_Footer")
</body>
</html>

