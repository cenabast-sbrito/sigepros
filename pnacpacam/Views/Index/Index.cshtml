<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Expires" content="0">
    <meta http-equiv="Last-Modified" content="0">
    <meta http-equiv="Cache-Control" content="no-cache, mustrevalidate">
    <meta http-equiv="Pragma" content="no-cache">

    <title>@ViewBag.Title</title>


    @Styles.Render("~/css")
    @Styles.Render("~/plugins-css")
    @Styles.Render("~/datatableExport-css")


</head>
<body>

    <header>
        <div class="navbar navbar-default navbar-fixed-top">
            <div class="container-fluid">
                <div class="navbar-header">
                    <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
                        <span class="icon-bar"></span>
                        <span class="icon-bar"></span>
                        <span class="icon-bar"></span>
                    </button>
                    <a href="#"><img alt="Brand" src="https://aplicacionesweb.cenabast.cl/icp/bootstrap/img/logotipo3.png"></a>
                    <p style=" font-family: var(--fontFamilyBase); font-size: var(--fontSizeMedium); color: var(--colorNeutralTexto);">release 2.1.9</p> 
                </div>
            </div>
        </div>
    </header>

    @{
        string imagen = Url.Content("~/Content/img/SIGEPROS - LOGO - short.png");
    }

    <main>


        <div>
                <div class="row align-items-center">

                    <!-- Imagen a la izquierda -->
                    <div class="col-md-6 text-center text-md-start">
                        <div class="row col-md-12" style="margin:25px auto;">

                            <img src="@imagen" alt="SIGEPROS - Sistema de Gestión de Expedientes de Programas de Salud"
                                 style="width: 40vw;margin-top: 8vw;">

                            <center style="font-family: var(--fontFamilyBase); font-size: var(--fontSizeMedium); color: var(--colorNeutralTexto) ">Herramienta de apoyo a la gestión operativa y documental de los programas nutricionales e inmunización</center>
                        </div>
                    </div>

                    <!-- Texto a la derecha -->
                    <div class="col-md-6">


                        <div class="row col-md-12" style=" margin-top: 6vw;">
                            <div class="container col-md-12" style="background-color: white; padding:40px 20px 80px 20px;">

                                @*<center><h2>SISTEMA DE GESTIÓN DE LOS EXPEDIENTES DE LOS PROGRAMAS DE SALUD PNAC–PACAM Y PNI</h2></center><hr>*@
                                

                                @*<hr>*@

                                <center>

                                    <div class="row">

                                        <form class="" id="formLogin" method="post" style="border: 1px solid; padding: 25px; width: max-content; align-items: center; border-color: #eeeeee;">
                                            @Html.AntiForgeryToken()
                                            <center><h3>Ingreso</h3></center>
                                            <div class="form-group">
                                                <label>Usuario</label>
                                                <input type="text" class="form-control required rut" id="rutusername" name="rutusername" placeholder="Rut" aria-required="true">
                                            </div>
                                            <div class="form-group">
                                                <label>Programa</label>
                                                <select id="programa" class="form-control required" name="programa" placeholder="Programa" aria-required="true">
                                                    <option value="0">PNAC-PACAM</option>
                                                    <option value="1">PNI</option>
                                                </select>
                                            </div>
                                            <div class="form-group">
                                                <label>Password</label>
                                                <input type="password" class="form-control required" id="password" name="password" placeholder="Password" aria-required="true">
                                            </div>
                                            <div class="form-group">
                                                <button type="submit" class="btn btn-block btn-principal">Ingresar</button>
                                                <div id="message"></div>
                                            </div>
                                        </form>

                                    </div>
                                </center>

                            </div>
                        </div>









                    </div>

                </div>
            </div>

            <div class="container-fluid margin-top">

                <script type="text/javascript" src="https://code.jquery.com/jquery-3.7.1.js"></script>
                <script type="text/javascript" src="https://cdn.datatables.net/2.0.1/js/dataTables.js"></script>
                <script type="text/javascript" src="https://cdn.datatables.net/buttons/3.0.0/js/dataTables.buttons.js"></script>
                <script type="text/javascript" src="https://cdn.datatables.net/buttons/3.0.0/js/buttons.dataTables.js"></script>
                <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
                <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
                <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>
                <script type="text/javascript" src="https://cdn.datatables.net/buttons/3.0.0/js/buttons.html5.min.js"></script>
                <script type="text/javascript" src="https://cdn.datatables.net/buttons/3.0.0/js/buttons.print.min.js"></script>

                @Scripts.Render("~/core-js")
                @Scripts.Render("~/plugins-js")

                @*<script type="text/javascript" src="Url.Content("~/app" + "?v=" + File.GetLastWriteTime(HttpContext.Current.Request.MapPath("~/Scripts/js/app/app.js")).ToString("yyyyMMddHHHmm"))"></script>*@
                <script type="text/javascript" src="@Url.Content("~/administraFormularios" + "?v=" + File.GetLastWriteTime(HttpContext.Current.Request.MapPath("~/Scripts/js/app/administraFormularios.js")).ToString("yyyyMMddHHHmm"))"></script>
                <script type="text/javascript" src="@Url.Content("~/usuarios" + "?v=" + File.GetLastWriteTime(HttpContext.Current.Request.MapPath("~/Scripts/js/app/usuarios.js")).ToString("yyyyMMddHHHmm"))"></script>
                <script type="text/javascript" src="@Url.Content("~/factura" + "?v=" + File.GetLastWriteTime(HttpContext.Current.Request.MapPath("~/Scripts/js/app/_factura.js")).ToString("yyyyMMddHHHmm"))"></script>
                <script type="text/javascript" src="@Url.Content("~/guia" + "?v=" + File.GetLastWriteTime(HttpContext.Current.Request.MapPath("~/Scripts/js/app/_guia.js")).ToString("yyyyMMddHHHmm"))"></script>
                <script type="text/javascript" src="@Url.Content("~/proveedor" + "?v=" + File.GetLastWriteTime(HttpContext.Current.Request.MapPath("~/Scripts/js/app/_proveedor.js")).ToString("yyyyMMddHHHmm"))"></script>
                <script type="text/javascript" src="@Url.Content("~/zdis022" + "?v=" + File.GetLastWriteTime(HttpContext.Current.Request.MapPath("~/Scripts/js/app/_zdis022.js")).ToString("yyyyMMddHHHmm"))"></script>

                <script type="text/javascript" src="@Url.Content("~/login" + "?v=" + File.GetLastWriteTime(HttpContext.Current.Request.PhysicalApplicationPath).ToString("yyyyMMddHHHmm"))"></script>

            </div>
            <!--fin side bar-->
</main>
    @Html.Partial("_Footer")
</body>
</html>

